<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🎂 <%= blessing.name %> 的生日祝福</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      background: linear-gradient(160deg, #fce4ec 0%, #f8bbd0 25%, #f48fb1 50%, #ba68c8 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      overflow-x: hidden;
    }

    /* Animated background decorations */
    .bg-decoration {
      position: fixed;
      pointer-events: none;
      z-index: 0;
      opacity: 0.12;
      font-size: 50px;
    }

    .bg-1 { top: 5%; left: 5%; animation: float 6s ease-in-out infinite; }
    .bg-2 { top: 15%; right: 8%; animation: float 8s ease-in-out 1s infinite; font-size: 40px; }
    .bg-3 { bottom: 20%; left: 10%; animation: float 7s ease-in-out 2s infinite; font-size: 35px; }
    .bg-4 { bottom: 10%; right: 5%; animation: float 9s ease-in-out 0.5s infinite; }
    .bg-5 { top: 50%; left: 3%; animation: float 6.5s ease-in-out 1.5s infinite; font-size: 30px; }
    .bg-6 { top: 40%; right: 4%; animation: float 8.5s ease-in-out 2.5s infinite; font-size: 45px; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      33% { transform: translateY(-15px) rotate(5deg); }
      66% { transform: translateY(10px) rotate(-5deg); }
    }

    /* Sparkle particles */
    .sparkles {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .sparkle {
      position: absolute;
      width: 4px; height: 4px;
      border-radius: 50%;
      background: #fff;
      animation: sparkle 3s ease-in-out infinite;
    }

    @keyframes sparkle {
      0%, 100% { opacity: 0; transform: scale(0); }
      50% { opacity: 0.8; transform: scale(1); }
    }

    .container {
      width: 100%;
      max-width: 480px;
      position: relative;
      z-index: 1;
    }

    .card {
      background: rgba(255, 255, 255, 0.93);
      border-radius: 28px;
      padding: 44px 32px 36px;
      box-shadow: 0 24px 80px rgba(156, 39, 176, 0.25), 0 0 0 1px rgba(255,255,255,0.4);
      backdrop-filter: blur(10px);
      text-align: center;
      animation: cardIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(30px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Photo */
    .photo-wrapper {
      margin-bottom: 24px;
    }

    .photo {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #f48fb1;
      box-shadow: 0 8px 32px rgba(233, 30, 99, 0.2);
      animation: photoIn 1s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }

    .photo-placeholder {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      background: linear-gradient(135deg, #f8bbd0, #f48fb1);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 72px;
      border: 4px solid #f48fb1;
      box-shadow: 0 8px 32px rgba(233, 30, 99, 0.2);
      animation: photoIn 1s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
      color: white;
    }

    @keyframes photoIn {
      from { opacity: 0; transform: scale(0.5); }
      to { opacity: 1; transform: scale(1); }
    }

    /* Greeting */
    .greeting {
      font-size: 16px;
      color: #e91e63;
      font-weight: 600;
      margin-bottom: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      animation: fadeUp 0.8s ease 0.4s both;
    }

    .name {
      font-size: 36px;
      font-weight: 800;
      color: #333;
      margin-bottom: 20px;
      animation: fadeUp 0.8s ease 0.5s both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Message */
    .message-box {
      background: linear-gradient(135deg, #fef5f8, #fce4ec);
      border-radius: 16px;
      padding: 24px 20px;
      margin-bottom: 24px;
      position: relative;
      animation: fadeUp 0.8s ease 0.6s both;
    }

    .message-box::before {
      content: '❤️';
      position: absolute;
      top: -16px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 28px;
    }

    .message-text {
      font-size: 17px;
      line-height: 1.8;
      color: #555;
      white-space: pre-wrap;
    }

    /* Sender */
    .sender {
      font-size: 15px;
      color: #e91e63;
      font-weight: 600;
      margin-bottom: 20px;
      animation: fadeUp 0.8s ease 0.7s both;
    }

    /* Birthday info */
    .birthday-info {
      display: inline-block;
      background: #fef5f8;
      border: 1px solid #f0d0dc;
      border-radius: 20px;
      padding: 8px 20px;
      font-size: 13px;
      color: #999;
      margin-bottom: 20px;
      animation: fadeUp 0.8s ease 0.75s both;
    }

    /* Decorations */
    .decorations {
      font-size: 32px;
      letter-spacing: 8px;
      animation: fadeUp 0.8s ease 0.8s both;
      margin-bottom: 8px;
    }

    /* Footer */
    .footer-note {
      font-size: 12px;
      color: #bbb;
      margin-top: 16px;
    }

    .footer-note a {
      color: #e91e63;
      text-decoration: none;
    }

    /* Responsive */
    @media (max-width: 480px) {
      .card { padding: 32px 20px 28px; }
      .name { font-size: 28px; }
      .photo, .photo-placeholder { width: 140px; height: 140px; }
      .photo-placeholder { font-size: 56px; }
      .message-text { font-size: 15px; }
    }
  </style>
</head>
<body>
  <!-- Background decorations -->
  <div class="bg-decoration bg-1">🎈</div>
  <div class="bg-decoration bg-2">🎁</div>
  <div class="bg-decoration bg-3">🎂</div>
  <div class="bg-decoration bg-4">🎉</div>
  <div class="bg-decoration bg-5">🎊</div>
  <div class="bg-decoration bg-6">💝</div>

  <!-- Sparkles -->
  <div class="sparkles" id="sparkles"></div>

  <div class="container">
    <div class="card">
      <!-- Photo -->
      <div class="photo-wrapper">
        <% if (blessing.photo) { %>
          <img class="photo" src="<%= blessing.photo %>" alt="<%= blessing.name %> 的照片">
        <% } else { %>
          <div class="photo-placeholder">🎂</div>
        <% } %>
      </div>

      <!-- Name -->
      <div class="greeting">✨ HAPPY BIRTHDAY ✨</div>
      <div class="name"><%= blessing.name %></div>

      <!-- Message -->
      <div class="message-box">
        <div class="message-text"><%= blessing.message %></div>
      </div>

      <!-- Sender -->
      <% if (blessing.sender) { %>
        <div class="sender">— <%= blessing.sender %></div>
      <% } %>

      <!-- Birthday -->
      <% if (blessing.birthday) { %>
        <div class="birthday-info">🎂 <%= blessing.birthday %></div>
      <% } %>

      <!-- Decorations -->
      <div class="decorations">🎈 🎂 🎁 🎉 🎊</div>

      <div class="footer-note">
        扫码获取专属生日祝福 · <a href="/">做一个祝福</a>
      </div>
    </div>
  </div>

  <script>
    // Generate sparkles
    const sparklesContainer = document.getElementById('sparkles');
    for (let i = 0; i < 30; i++) {
      const sparkle = document.createElement('div');
      sparkle.className = 'sparkle';
      sparkle.style.left = Math.random() * 100 + '%';
      sparkle.style.top = Math.random() * 100 + '%';
      sparkle.style.animationDelay = Math.random() * 3 + 's';
      sparkle.style.animationDuration = (2 + Math.random() * 3) + 's';
      sparklesContainer.appendChild(sparkle);
    }
  </script>
</body>
</html>
